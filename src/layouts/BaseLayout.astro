---
import '../styles/main.scss';

export interface Props {
  title: string;
  description?: string;
  isHome?: boolean;
}

const { title, description, isHome = false } = Astro.props;
const siteTitle = 'Lemonochrome - Portfolio';
const pageTitle = title === 'Home' ? siteTitle : `${title} · ${siteTitle}`;

const nav = [
  { title: 'Posts', url: '/archive' },
  { title: 'About', url: '/about' },
  { title: 'Resume', url: '/resume' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    {description && <meta name="description" content={description} />}
    <link rel="apple-touch-icon-precomposed" sizes="144x144" href="/assets/apple-touch-icon-precomposed.png" />
    <link rel="shortcut icon" href="/assets/favicon.png" />
    <link rel="alternate" type="application/atom+xml" title={siteTitle} href="/atom.xml" />
    <script type="text/javascript" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
    <script is:inline>
      MathJax = {
        tex: {
          inlineMath: [['$', '$'], ['\\(', '\\)']],
          displayMath: [['$$', '$$'], ['\\[', '\\]']]
        }
      };
    </script>
  </head>

  <body style="display: flex; flex-direction: column; min-height: 100vh; margin: 0;">
    <div class="container content" style="flex: 1;">
      <header class="masthead">
        <h3 class="masthead-title">
          <a href="/" title="Home" style="display: inline-block; vertical-align: middle;">
            <img id="logo" src="/assets/logo-light.png" alt="Lemonochrome Logo"
              style="width: 100px; height: auto; vertical-align: middle;" />
          </a>

          <!-- Burger Menu Button -->
          <button class="burger" aria-label="Toggle navigation">&#9776;</button>

          <!-- Navigation Menu -->
          <nav class="nav">
            {nav.map(item => (
              <small>
                <a href={item.url} class="hover-link">{item.title}</a>
              </small>
            ))}

            <small>
              <button id="theme-toggle" style="background: none; border: none; color: inherit; cursor: pointer; font: inherit;">
                <span id="theme-icon" class="hover-cool">✷</span>
              </button>
            </small>
          </nav>

          <!-- ALL JS Combined -->
          <script>
            document.addEventListener('DOMContentLoaded', () => {
              // Burger toggle
              const burger = document.querySelector('.burger');
              const nav = document.querySelector('.nav');
              burger.addEventListener('click', (e) => {
                nav.classList.toggle('show');
                e.stopPropagation();
              });

              // Hide nav when clicking outside
              document.addEventListener('click', (e) => {
                if (nav.classList.contains('show') && !nav.contains(e.target) && !burger.contains(e.target)) {
                  nav.classList.remove('show');
                }
              });

              // Theme toggle
              const themeToggle = document.getElementById('theme-toggle');
              const themeIcon = document.getElementById('theme-icon');
              const logo = document.getElementById('logo');

              function updateLogo() {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                logo.src = currentTheme === 'dark-pool'
                  ? '/assets/logo-light.png'
                  : '/assets/logo-dark.png';
              }

              themeToggle.addEventListener('click', () => {
                const html = document.documentElement;
                const currentTheme = html.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark-pool' ? 'light' : 'dark-pool';
                html.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);
                themeIcon.textContent = '✷';
                updateLogo();
              });

              const savedTheme = localStorage.getItem('theme');
              if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
                themeIcon.textContent = '✷';
              } else {
                document.documentElement.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
                themeIcon.textContent = '✷';
              }

              updateLogo();
            });
          </script>
        </h3>
      </header>

      <main>
        {isHome && (
          <>
            <br /><br />

            <!-- Animated Title -->
            <p class="fade-in-main-title">
              Robin Marin–Muller
            </p>
            <p class="fade-in-title" style="text-align: center; font-size: 1em;">@Lemonochrome</p>

            <p class="fade-in-description" style="text-align: center;">
              <span class="contact-desktop">
                <a href="mailto:marin-muller@insa-toulouse.fr" class="hover-link">Email Me</a> |
                <a href="http://github.com/Lemonochrme/" target="_blank" class="hover-link">GitHub</a> |
                <a href="https://medium.com/@Lemonochrome" target="_blank" class="hover-link">Medium</a> |
                <a href="/resume/" class="hover-link">View Curriculum Vitae</a>
              </span>
              <span class="contact-mobile" style="display:none;">
                <a href="mailto:marin-muller@insa-toulouse.fr" class="hover-link">Email</a> |
                <a href="http://github.com/Lemonochrme/" target="_blank" class="hover-link">GitHub</a> |
                <a href="https://medium.com/@Lemonochrome" target="_blank" class="hover-link">Medium</a> |
                <a href="/resume/" class="hover-link">CV</a>
              </span>

              <style>{`
                @media (max-width: 720px) {
                  .contact-desktop { display: none !important; font-style: italic; margin: 0 0.5rem;}
                  .contact-mobile { display: inline !important; font-style: italic; margin: 0 0.5rem;}
                  .fade-in-description {
                    text-align: center !important;
                  }
                }
                @media (min-width: 721px) {
                  .contact-desktop { display: inline !important; font-style: italic; margin: 0 0.5rem;}
                  .contact-mobile { display: none !important; font-style: italic; margin: 0 0.5rem;}
                }
              `}</style>
            </p>

            <!-- Animated Description -->
            <p class="fade-in-description">
              I like to understand how complex systems work: signals, control, electronics, firmware, architecture, and the scientific principles behind them. Here are some of the systems I've designed, built, and analysed as an engineering student at INSA Toulouse.
            </p>

            <div class="button-container">
              <!-- Animated Button -->
              <a href="/archive" class="btn-outline fade-in-button">
                ✦ Discover the Projects
              </a>
            </div>

            <style>{`
              /* === Fade-in Animations === */
              @keyframes fadeInUp {
                0% { opacity: 0; transform: translateY(20px); }
                100% { opacity: 1; transform: translateY(0); }
              }

              .fade-in-title {
                opacity: 0;
                animation: fadeInUp 1s ease-out forwards;
              }

              .fade-in-main-title {
                opacity: 0;
                animation: fadeInUp 1.42s ease-out forwards;
                text-align: center;
                font-size: 2em;
              }

              .button-container {
                text-align: right;
              }

              @media (max-width: 720px) {
                .fade-in-main-title { font-size: 1.4em; }
                .button-container { text-align: center; }
              }

              .fade-in-description {
                opacity: 0;
                animation: fadeInUp 1s ease-out forwards;
                animation-delay: 0.3s;
              }

              .fade-in-link {
                opacity: 0;
                animation: fadeInUp 1s ease-out forwards;
                animation-delay: 0.3s;
              }

              .fade-in-button {
                opacity: 0;
                animation: fadeInUp 1s ease-out forwards;
                animation-delay: 0.6s;
              }

              /* === Button Styling === */
              .btn-outline {
                display: inline-block;
                padding: 10px 20px;
                font-size: 20px;
                color: var(--link-color);
                border: 2px solid var(--link-color);
                text-decoration: none;
                transition: background-color 0.4s, color 0.3s;
                position: relative;
                overflow: hidden;
              }

              .btn-outline:hover {
                color: var(--body-bg);
                background-color: var(--link-color);
              }

              /* === Hover Link Styling === */
              .hover-link {
                color: var(--link-color);
                text-decoration: none;
                position: relative;
                transition: color 0.3s ease;
              }

              .hover-link::after {
                content: "";
                display: block;
                width: 0;
                height: 2px;
                background: var(--link-color);
                transition: width 0.3s ease;
                position: absolute;
                left: 0;
                bottom: -2px;
              }

              .hover-link:hover { color: var(--link-hover-color); }
              .hover-link:hover::after { width: 100%; }

              .hover-cool {
                display: inline-block;
                transition: transform 0.3s ease;
                font-size: larger;
              }

              .hover-cool:hover { transform: rotate(360deg); }

              body {
                background-color: var(--body-bg);
                color: var(--body-color);
              }

              h1, h2, h3, h4, h5, h6 { color: var(--heading-color); }

              code {
                background-color: var(--code-bg);
                padding: 2px 4px;
                border-radius: 4px;
                font-family: 'Courier New', Courier, monospace;
              }

              hr { border-color: var(--border-color); }
            `}</style>
          </>
        )}

        {!isHome && <slot />}
      </main>
    </div>

    <footer class="footer" style="text-align: center; padding: 10px 0; width: 100%;">
      <small>
        &copy; {new Date().getFullYear()}. All rights reserved.
        <div style="text-align: center; font-size: 0.7em; color: var(--border-color); margin-top: 16px;"></div>
        {isHome && <span>C'est véritablement utile puisque c'est joli.</span>}
      </small>
    </footer>
  </body>
</html>
