---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout isHome={true}>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
  <link href="https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />

  <br /><br />

  <!-- Animated Title -->
  <p class="fade-in-main-title">
    Robin Marin–Muller
  </p>
  <p class="fade-in-title" style="text-align: center; font-size: 1em;">@Lemonochrome</p>

  <p class="fade-in-description" style="text-align: center;">
    <span class="contact-desktop">
      <a href="mailto:marin-muller@insa-toulouse.fr" class="hover-link">Email Me</a> |
      <a href="http://github.com/Lemonochrme/" target="_blank" class="hover-link">GitHub</a> |
      <a href="https://medium.com/@Lemonochrome" target="_blank" class="hover-link">Medium</a> |
      <a href="/resume/" class="hover-link">View Curriculum Vitae</a>
    </span>
    <span class="contact-mobile" style="display:none;">
      <a href="mailto:marin-muller@insa-toulouse.fr" class="hover-link">Email</a> |
      <a href="http://github.com/Lemonochrme/" target="_blank" class="hover-link">GitHub</a> |
      <a href="https://medium.com/@Lemonochrome" target="_blank" class="hover-link">Medium</a> |
      <a href="/resume/" class="hover-link">CV</a>
    </span>

    <style>
      @media (max-width: 720px) {
        .contact-desktop { display: none !important; font-style: italic; margin: 0 0.5rem; }
        .contact-mobile { display: inline !important; font-style: italic; margin: 0 0.5rem; }
        .fade-in-description { text-align: center !important; }
      }
      @media (min-width: 721px) {
        .contact-desktop { display: inline !important; font-style: italic; margin: 0 0.5rem; }
        .contact-mobile { display: none !important; font-style: italic; margin: 0 0.5rem; }
      }
    </style>
  </p>

  <!-- Animated Description -->
  <p class="fade-in-description">
    I like to understand how complex systems work: signals, control, electronics, firmware, architecture, and the scientific principles behind them. Here are some of the systems I've designed, built, and analysed as an engineering student at INSA Toulouse.
  </p>

  <div class="button-container">
    <a href="/archive" class="btn-outline fade-in-button">
      ✦ Discover the Projects
    </a>
  </div>

  <style>
    /* === Fade-in Animations === */
    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    .fade-in-title {
      opacity: 0;
      animation: fadeInUp 1s ease-out forwards;
    }

    .fade-in-main-title {
      opacity: 0;
      animation: fadeInUp 1.42s ease-out forwards;
      text-align: center;
      font-size: 2em;
    }

    .button-container { text-align: right; }

    @media (max-width: 720px) {
      .fade-in-main-title { font-size: 1.4em; }
      .button-container { text-align: center; }
    }

    .fade-in-description {
      opacity: 0;
      animation: fadeInUp 1s ease-out forwards;
      animation-delay: 0.3s;
    }

    .fade-in-button {
      opacity: 0;
      animation: fadeInUp 1s ease-out forwards;
      animation-delay: 0.6s;
    }

    /* === Button Styling === */
    .btn-outline {
      display: inline-block;
      padding: 10px 20px;
      font-size: 20px;
      color: var(--link-color);
      border: 2px solid var(--link-color);
      text-decoration: none;
      transition: background-color 0.4s, color 0.3s;
      position: relative;
      overflow: hidden;
    }

    .btn-outline:hover {
      color: var(--body-bg);
      background-color: var(--link-color);
    }

    /* === Hover Link Styling === */
    .hover-link {
      color: var(--link-color);
      text-decoration: none;
      position: relative;
      transition: color 0.3s ease;
    }

    .hover-link::after {
      content: "";
      display: block;
      width: 0;
      height: 2px;
      background: var(--link-color);
      transition: width 0.3s ease;
      position: absolute;
      left: 0;
      bottom: -2px;
    }

    .hover-link:hover { color: var(--link-hover-color); }
    .hover-link:hover::after { width: 100%; }

    .hover-cool {
      display: inline-block;
      transition: transform 0.3s ease;
      font-size: larger;
    }

    .hover-cool:hover { transform: rotate(360deg); }

    body {
      background-color: var(--body-bg);
      color: var(--body-color);
    }

    h1, h2, h3, h4, h5, h6 { color: var(--heading-color); }

    code {
      background-color: var(--code-bg);
      padding: 2px 4px;
      border-radius: 4px;
      font-family: 'Courier New', Courier, monospace;
    }

    hr { border-color: var(--border-color); }
  </style>
</BaseLayout>
