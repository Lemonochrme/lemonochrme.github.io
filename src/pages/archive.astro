---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');

// Group posts by category
const personalPosts = allPosts
  .filter(p => p.data.categories.includes('Personnal'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const insaPosts = allPosts
  .filter(p => p.data.categories.includes('INSA'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function groupByYearMonth(posts: typeof allPosts) {
  const groups: Record<string, typeof allPosts> = {};
  for (const post of posts) {
    const key = post.data.date.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' });
    if (!groups[key]) groups[key] = [];
    groups[key].push(post);
  }
  return groups;
}

const personalByMonth = groupByYearMonth(personalPosts);
const insaByMonth = groupByYearMonth(insaPosts);
---

<BaseLayout title="Projects Archive">
  <div class="projects-container">

    <!-- Personal Portfolio Section -->
    <p class="portfolio-title">Personal Portfolio</p>
    {Object.entries(personalByMonth).map(([month, posts], i) => (
      <>
        <p class="year-month fade-in">{month}</p>
        <div class="projects-list">
          {posts.map((post, j) => (
            <div class="project-item fade-in" style={`animation-delay: ${(j + 1) * 0.1}s`}>
              <a href={`/posts/${post.id}`} class="project-link">
                <h3 class="project-title">{post.data.title}</h3>
                <p class="project-description">
                  {post.data.description
                    ? post.data.description.slice(0, 150)
                    : ''}
                </p>
              </a>
            </div>
          ))}
        </div>
      </>
    ))}

    <!-- INSA Portfolio Section -->
    <p class="portfolio-title">INSA Portfolio</p>
    {Object.entries(insaByMonth).map(([month, posts]) => (
      <>
        <p class="year-month fade-in">{month}</p>
        <div class="projects-list">
          {posts.map((post, j) => (
            <div class="project-item fade-in" style={`animation-delay: ${(j + 1) * 0.1}s`}>
              <a href={`/posts/${post.id}`} class="project-link">
                <h3 class="project-title">{post.data.title}</h3>
                <p class="project-description">
                  {post.data.description
                    ? post.data.description.slice(0, 150)
                    : ''}
                </p>
              </a>
            </div>
          ))}
        </div>
      </>
    ))}

  </div>

  <style>
    .projects-container {
      max-width: 800px;
      margin: 0 auto;
    }

    .portfolio-title {
      font-size: 2rem;
      margin-top: 20px;
    }

    .year-month {
      font-size: 1.5rem;
      margin-top: 30px;
    }

    .projects-list {
      display: flex;
      flex-direction: column;
      gap: 20px;
      margin-top: 20px;
    }

    .project-item {
      padding: 15px 20px;
      border: 1px solid var(--border-color, #444);
      border-radius: 12px;
      background: rgba(255, 255, 255, 0.02);
      transition: background-color 0.3s, border-color 0.3s;
    }

    .project-item:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: #7cc6fe;
    }

    .project-link {
      text-decoration: none;
      color: inherit;
      display: block;
    }

    .project-title {
      font-size: 1.4rem;
      margin: 0 0 8px;
      font-weight: 600;
    }

    .project-description {
      margin: 0;
      font-size: 1rem;
      line-height: 1.5;
    }

    .fade-in {
      opacity: 0;
      transform: translateY(20px);
      animation: fadeInUp 0.6s ease forwards;
    }

    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(20px); }
      100% { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 600px) {
      .projects-container { padding: 15px; }
      .project-title { font-size: 1.2rem; }
      .project-description { font-size: 0.95rem; }
    }
  </style>
</BaseLayout>
